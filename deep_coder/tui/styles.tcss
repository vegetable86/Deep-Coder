Screen {
    layout: vertical;
}

#timeline-scroll {
    height: 1fr;
    overflow-y: auto;
}

#timeline {
    width: 100%;
    padding: 1 2;
}

#question-widget {
    margin: 0 2 1 2;
}

#bottom-pane {
    height: 12;
    layout: vertical;
    border-top: solid $primary;
}

#status-strip {
    height: 1;
    padding: 0 1;
}

#command-palette {
    height: 4;
    border: round $primary;
    margin: 0 1;
}

#composer {
    height: 1fr;
}
